OPENAI_API_KEY=replace-with-real-key
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/rag
MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO

# Phase 1 security controls
AUTH_REQUIRED=true
JWT_SECRET_KEY=replace-with-64-char-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_USERS_JSON=[{"username":"admin","password":"replace-admin-password","role":"admin","collections":["*"]},{"username":"viewer","password":"replace-viewer-password","role":"viewer","collections":["HR-docs"]}]
MAX_UPLOAD_SIZE_MB=50
DEFAULT_RATE_LIMIT=120/minute
AUTH_RATE_LIMIT=20/minute
CHAT_RATE_LIMIT=60/minute
UPLOAD_RATE_LIMIT=10/minute

# Phase 2 production hardening
POOL_SIZE=20
MAX_OVERFLOW=10
POOL_TIMEOUT_SECONDS=30
POOL_RECYCLE_SECONDS=1800
IVFFLAT_LISTS=100
HEALTH_OPENAI_TIMEOUT_SECONDS=8

# Phase 3 enterprise controls
API_VERSION_PREFIX=/v1
DB_AUTH_ENABLED=true
API_KEY_PREFIX=rk_
DEFAULT_USER_QUOTA_PER_MONTH=10000
DEFAULT_API_KEY_QUOTA_PER_MONTH=5000
OIDC_ISSUER_URL=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_CLAIM_USERNAME=email
OIDC_CLAIM_ROLE=role
OIDC_CLAIM_COLLECTIONS=collections

# Phase 4 differentiation
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai
DATA_SOVEREIGNTY_MODE=false
LOCAL_PROVIDER_API_KEY=local-inference
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL_DEFAULT=llama3.1:8b-instruct-q4_K_M
LOCAL_LLM_MODEL_FI=poro-34b-chat
LOCAL_EMBEDDING_BASE_URL=http://localhost:11434/v1
LOCAL_EMBEDDING_MODEL=nomic-embed-text
TURKUNLP_EMBEDDING_URL=
TURKUNLP_EMBEDDING_API_KEY=
CONNECTOR_FETCH_TIMEOUT_SECONDS=20
CONNECTOR_MAX_SOURCES_PER_IMPORT=20
CONNECTOR_ALLOWED_DOMAINS=
